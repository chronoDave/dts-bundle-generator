{
  "private": true,
  "name": "dts-bundle-generator",
  "version": "9.5.1",
  "description": "DTS Bundle Generator",
  "main": "dist/bundle-generator.js",
  "typings": "dist/bundle-generator.d.ts",
  "bin": "dist/bin/dts-bundle-generator.js",
  "type": "module",
  "files": [
    "config-schema.d.ts",
    "dist/**/*.d.ts",
    "dist/**/*.js"
  ],
  "author": "Chronocide",
  "contributors": [{
    "name": "Evgeniy Timokhov",
    "url": "https://github.com/timocov/dts-bundle-generator"
  }],
  "bugs": {
    "url": "https://github.com/chronoDave/dts-bundle-generator/issues"
  },
  "homepage": "https://github.com/chronoDave/dts-bundle-generator",
  "dependencies": {
    "typescript": ">=5.0.2",
    "yargs": "^17.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/yargs": "~17.0.13",
    "@typescript-eslint/eslint-plugin": "~7.4.0",
    "@typescript-eslint/parser": "~7.4.0",
    "eslint": "~8.57.0",
    "eslint-plugin-deprecation": "~2.0.0",
    "eslint-plugin-import": "~2.29.0",
    "eslint-plugin-unicorn": "~51.0.1",
    "ts-compiler": "npm:typescript@5.4.3"
  },
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chronoDave/dts-bundle-generator.git"
  },
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "clean": "node scripts/clean.ts",
    "lint": "eslint --format=unix ./",
    "check-dts-config": "node ./node_modules/ts-compiler/bin/tsc -p tsconfig.dts-config.json",
    "bundle-dts": "npm run check-dts-config && node ./dist/bin/dts-bundle-generator.js --config dts-config.js --silent",
    "tsc": "node ./node_modules/ts-compiler/bin/tsc --version && node ./node_modules/ts-compiler/bin/tsc -b ./tsconfig.json",
    "verify": "npm run clean && npm run tsc -p && npm run bundle-dts && npm run lint -s && npm run test",
    "prepare-release": "nrpm run clean && npm run tsc && npm run bundle-dts && node scripts/clean-package-json.js",
    "test": "node --test tests/**/*.spec.ts"
  }
}
